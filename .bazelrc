# How to compile target code
build --java_language_version=17
build --java_runtime_version=remotejdk_17

# How to compile and run build tools (like AddJarManifestEntry)
build --tool_java_language_version=11
build --tool_java_runtime_version=remotejdk_11

#build --modify_execution_info=StampJarManifest=+remote

# C++ toolchain flags
build --cxxopt=-std=c++17
build --host_cxxopt=-std=c++17

#build:remote --cxxopt=-stdlib=libstdc++
#build:remote --host_cxxopt=-stdlib=libstdc++
#build:remote --linkopt=-stdlib=libstdc++
#build:remote --host_linkopt=-stdlib=libstdc++

build --cxxopt=-stdlib=libc++
build --host_cxxopt=-stdlib=libc++
build --linkopt=-stdlib=libc++
build --host_linkopt=-stdlib=libc++

build --host_linkopt=-lc++abi
build --copt=-D_GLIBCXX_USE_CXX11_ABI=1
build --host_copt=-D_GLIBCXX_USE_CXX11_ABI=1
build --host_linkopt=-latomic
build --host_copt=-fsanitize=memory
build --host_linkopt=-fsanitize=memory
build --action_env=MSAN_OPTIONS="halt_on_error=0"

common --toolchain_resolution_debug='@rules_java//toolchains:bootstrap_runtime_toolchain_type'
common --toolchain_resolution_debug='@bazel_tools//tools/jdk:toolchain_type'